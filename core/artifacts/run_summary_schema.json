{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orket://core/artifacts/run_summary_schema.json",
  "title": "Run Summary Artifact",
  "type": "object",
  "required": [
    "run_id",
    "status",
    "duration_ms",
    "tools_used",
    "artifact_ids",
    "failure_reason"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "duration_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "tools_used": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "truthful_runtime_packet1": {
      "type": "object"
    },
    "truthful_runtime_packet2": {
      "type": "object"
    },
    "truthful_runtime_artifact_provenance": {
      "type": "object"
    },
    "control_plane": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
