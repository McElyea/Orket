    "canary_drop_first_run":  true,
    "canary_max_missing_telemetry_rate":  0.1,
    "row_max_missing_telemetry_rate":  0.12,
    "row_max_orchestration_overhead_ratio":  0.65,
    "row_max_cpu_saturation_rate":  0.035,
    "row_max_system_load_rate":  0,
    "context_sweep_profile":  "safe",
    "context_sweep_contexts":  [
                                   4096,
                                   8192,
                                   16384
                               ],
    "context_adherence_min":  0.95,
    "context_ttft_ceiling_ms":  250.0,
    "context_decode_floor_tps":  20.0
}
