{
  "models": [
    "qwen3.5-0.8b",
    "qwen3.5-2b",
    "qwen3.5-4b",
    "qwen3.5-27b",
    "qwen3.5-35b-a3b"
  ],
  "quants": [
    "Q8_0",
    "Q6_K",
    "Q4_K_M",
    "Q3_K_L"
  ],
  "task_bank": "benchmarks/task_bank/v2_realworld/tasks.json",
  "runs_per_quant": 2,
  "task_limit": 0,
  "runtime_target": "local-hardware",
  "execution_mode": "live-card",
  "runner_template": "python scripts/benchmarks/live_card_benchmark_runner.py --task {task_file} --runtime-target {runtime_target} --execution-mode {execution_mode} --run-dir {run_dir} --seed {seed} --threads {threads} --affinity-policy {affinity_policy} --warmup-steps {warmup_steps}",
  "runtime_env": {
    "ORKET_LLM_PROVIDER": "lmstudio",
    "ORKET_MODEL_PROVIDER": "lmstudio",
    "ORKET_LLM_OPENAI_BASE_URL": "http://127.0.0.1:1234/v1",
    "ORKET_MODEL_STREAM_OPENAI_BASE_URL": "http://127.0.0.1:1234/v1",
    "ORKET_BENCH_TEMPERATURE": "0.0"
  },
  "adherence_threshold": 0.9,
  "latency_ceiling": 12.0,
  "seed": 1337,
  "threads": 1,
  "affinity_policy": "all",
  "warmup_steps": 1,
  "canary_runs": 5,
  "canary_task_limit": 1,
  "canary_latency_variance_threshold": 0.05,
  "context_sweep_profile": "balanced",
  "context_sweep_contexts": [
    4096,
    16384,
    65536
  ],
  "context_adherence_min": 0.9,
  "context_ttft_ceiling_ms": 300.0,
  "context_decode_floor_tps": 10.0
}
