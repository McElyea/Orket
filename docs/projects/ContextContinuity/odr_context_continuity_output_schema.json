{
  "schema_version": "odr.context_continuity.compare_output_schema.v1",
  "last_updated": "2026-03-21",
  "description": "Lane-scoped output contract for ODR context continuity control, V0, and V1 comparison runs.",
  "continuity_mode_enum": [
    "control_current_replay",
    "v0_log_derived_replay",
    "v1_compiled_state"
  ],
  "evidence_scope_enum": [
    "single_pair_bounded",
    "primary_plus_sensitivity",
    "full_matrix"
  ],
  "verdict_enum": [
    "worthwhile_at_5_rounds",
    "worthwhile_at_9_rounds",
    "worthwhile_at_both_locked_budgets",
    "continuity_quality_success_only",
    "not_materially_worthwhile"
  ],
  "top_level_required": [
    "schema_version",
    "generated_at",
    "ended_at",
    "lane_config_snapshot",
    "evidence_scope",
    "scenario_set",
    "continuity_modes",
    "scenario_runs",
    "pair_budget_aggregates",
    "budget_verdicts"
  ],
  "scenario_run_required": [
    "scenario_id",
    "pair_id",
    "continuity_mode",
    "locked_budget",
    "converged",
    "reopened_decision_count",
    "contradiction_count",
    "regression_count",
    "carry_forward_integrity",
    "median_round_latency_ms",
    "median_round_active_context_size_tokens"
  ],
  "pair_budget_aggregate_required": [
    "pair_id",
    "continuity_mode",
    "locked_budget",
    "scenario_run_count",
    "convergence_rate",
    "reopened_decision_rate",
    "contradiction_rate",
    "regression_rate",
    "carry_forward_integrity",
    "median_round_latency_ms",
    "median_round_active_context_size_tokens"
  ],
  "budget_verdict_required": [
    "continuity_mode",
    "locked_budget",
    "pair_scope",
    "evidence_scope",
    "verdict",
    "threshold_inputs",
    "absolute_converged_case_delta",
    "percentage_point_convergence_delta",
    "disqualifying_regressions"
  ]
}
