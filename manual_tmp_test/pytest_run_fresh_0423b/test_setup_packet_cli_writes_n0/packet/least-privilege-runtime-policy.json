{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadSmokeTerraformPlan",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::<replace-with-globally-unique-smoke-bucket>/orket/trusted-terraform-plan-decision/terraform-plan-safe-smoke.plan.json"
      ]
    },
    {
      "Sid": "InvokeConfiguredBedrockModel",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel"
      ],
      "Resource": [
        "arn:aws:bedrock:us-east-1:<account-id>:inference-profile/us.amazon.nova-lite-v1:0"
      ]
    },
    {
      "Sid": "WriteTerraformReviewAudit",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:<account-id>:table/TerraformReviews"
      ]
    }
  ]
}
